{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CheckPo",
  "version": "0.1.0",
  "identifier": "com.suu.checkpo",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CheckPo",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self'; script-src 'self'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0RTE4MTZERkNBQzM5QjAKUldTd09hejhiWUhoeE5EWFhYdDZqcXJGYWNldnAyYzI1Qzk0T3d5aHRmV1lVUDRra2xZNlZDeW0K",
      "endpoints": [
        "https://github.com/0suu/CheckPo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
